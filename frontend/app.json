{
  "expo": {
    "name": "ShieldHer",
    "slug": "shieldher",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "shieldher",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shieldher.app"
    },
    "android": {
      "package": "com.shieldher.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0D0B14"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "splash": {
        "image": "./assets/images/splash-image.png",
        "resizeMode": "contain",
        "backgroundColor": "#0D0B14"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "ShieldHer",
      "shortName": "ShieldHer",
      "description": "AI-powered women's safety platform — Travel Shield, Cyber Shield, and Career Growth in one premium app.",
      "themeColor": "#0D0B14",
      "backgroundColor": "#0D0B14",
      "display": "standalone",
      "orientation": "any",
      "startUrl": "/",
      "lang": "en"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0D0B14"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "b99b6f0e-c27b-41d8-8966-e3a570506425"
      },
      "router": {}
    },
    "owner": "shreya_singh4593",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b99b6f0e-c27b-41d8-8966-e3a570506425"
    }
  }
}
